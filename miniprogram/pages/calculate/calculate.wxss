.picker-card {
  min-height: 104rpx;
}

.form-brief {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  box-sizing: border-box;
  margin-top: 28rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid rgba(23, 107, 115, 0.12);
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F1F8F7 72%, #FFF9F0 100%);
  box-shadow: 0 12rpx 32rpx rgba(23, 50, 77, 0.06);
}

.scenario-banner {
  box-sizing: border-box;
  margin-top: 28rpx;
  padding: 22rpx 26rpx;
  border: 1rpx solid rgba(183, 121, 31, 0.18);
  border-radius: 18rpx;
  background: #FFF9F0;
}

.scenario-title {
  color: #17324D;
  font-size: 30rpx;
  font-weight: 800;
}

.scenario-desc {
  margin-top: 6rpx;
  color: #6B7A89;
  font-size: 26rpx;
}

.brief-title {
  color: #17324D;
  font-size: 30rpx;
  font-weight: 800;
}

.brief-desc {
  margin-top: 6rpx;
  color: #6B7A89;
  font-size: 25rpx;
  line-height: 1.4;
}

.brief-badge {
  flex-shrink: 0;
  min-height: 52rpx;
  padding: 0 16rpx;
  border-radius: 12rpx;
  background: #FFF5E6;
  color: #8A5A18;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.worker-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.option-card,
.city-card,
.contribution-card {
  box-sizing: border-box;
  padding: 26rpx 28rpx;
  border: 1rpx solid rgba(23, 107, 115, 0.1);
  border-radius: 18rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #FBFDFC 100%);
  box-shadow: 0 10rpx 28rpx rgba(23, 50, 77, 0.05);
}

.option-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-height: 96rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-word;
}

.option-label {
  flex: 1;
}

.option-card.selected,
.city-card.selected,
.contribution-card.selected {
  border-color: #176B73;
  background: linear-gradient(180deg, #F2FBFA 0%, #EAF4F5 100%);
  box-shadow: 0 12rpx 34rpx rgba(23, 107, 115, 0.14);
}

.option-hint {
  margin-top: 14rpx;
}

.city-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.city-card.blocked {
  background: rgba(255, 255, 255, 0.72);
}

.city-name {
  font-size: 32rpx;
  font-weight: 700;
}

.city-message {
  margin-top: 8rpx;
  color: #6B7A89;
  font-size: 26rpx;
}

.source-link {
  margin-top: 18rpx;
  color: #176B73;
  font-size: 28rpx;
}

.input-card {
  display: flex;
  align-items: center;
  min-height: 104rpx;
}

.input-card input {
  flex: 1;
  min-height: 88rpx;
  color: #17324D;
  font-size: 32rpx;
}

.input-unit {
  color: #6B7A89;
  font-size: 28rpx;
}

.contribution-title {
  margin-bottom: 6rpx;
  color: #17324D;
  font-size: 30rpx;
  font-weight: 700;
}

.contribution-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.amount-input {
  margin-top: 18rpx;
}

.more-contribution {
  margin-top: 18rpx;
  color: #176B73;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.account-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.account-title {
  color: #17324D;
  font-size: 30rpx;
  font-weight: 700;
}

.account-arrow {
  color: #176B73;
  font-size: 48rpx;
}

.form-error {
  margin-top: 28rpx;
}
