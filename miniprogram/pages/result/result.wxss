.result-hero {
  box-sizing: border-box;
  padding: 38rpx 32rpx 32rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #17324D 0%, #174B61 54%, #176B73 100%);
  color: #FFFFFF;
  box-shadow: 0 22rpx 56rpx rgba(23, 50, 77, 0.22);
}

.hero-caption {
  color: rgba(255, 255, 255, 0.76);
  font-size: 28rpx;
}

.amount-row {
  display: flex;
  align-items: baseline;
  margin-top: 18rpx;
}

.amount {
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1.1;
}

.amount-unit {
  margin-left: 10rpx;
  font-size: 32rpx;
}

.range {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 30rpx;
}

.result-note {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
}

.fact-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 14rpx 0;
}

.fact-label {
  flex-shrink: 0;
  color: #6B7A89;
}

.fact-value {
  color: #17324D;
  text-align: right;
}

.eligibility {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.eligibility.ok {
  background: #EAF7EF;
  color: #1F7A4D;
}

.eligibility.risk {
  background: #FDEDEC;
  color: #B42318;
}

.status-title {
  margin-bottom: 12rpx;
  color: #176B73;
  font-size: 32rpx;
  font-weight: 700;
}

.bullet {
  margin-top: 10rpx;
  color: #526375;
  font-size: 28rpx;
}

.source-link {
  margin-top: 18rpx;
  color: #176B73;
  font-size: 28rpx;
}

.warning-card {
  border-color: #F1D9B5;
  background: #FFF9F0;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.share-button {
  width: 100%;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(23, 107, 115, 0.14);
  line-height: normal;
}

.share-button::after {
  border: 0;
}

.empty-state {
  padding-top: 160rpx;
  text-align: center;
}

.empty-button {
  margin-top: 40rpx;
}
